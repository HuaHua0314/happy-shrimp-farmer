rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isFarmMember(farmId) {
      return signedIn()
        && exists(/databases/$(database)/documents/farms/$(farmId)/members/$(request.auth.uid));
    }

    function farmRole(farmId) {
      return get(/databases/$(database)/documents/farms/$(farmId)/members/$(request.auth.uid)).data.role;
    }

    function isFarmManager(farmId) {
      return isFarmMember(farmId)
        && farmRole(farmId) in ['owner', 'admin'];
    }

    function isFarmOwner(farmId) {
      return isFarmMember(farmId)
        && farmRole(farmId) == 'owner';
    }

    function isFarmCreator(farmId, uid) {
      return signedIn()
        && request.auth.uid == uid
        && get(/databases/$(database)/documents/farms/$(farmId)).data.ownerId == uid;
    }

    function hasValidInvite(farmId, uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.inviteId is string
        && exists(/databases/$(database)/documents/farmInvites/$(request.resource.data.inviteId))
        && get(/databases/$(database)/documents/farmInvites/$(request.resource.data.inviteId)).data.farmId == farmId
        && get(/databases/$(database)/documents/farmInvites/$(request.resource.data.inviteId)).data.phone == request.auth.token.phone_number
        && get(/databases/$(database)/documents/farmInvites/$(request.resource.data.inviteId)).data.status == 'pending';
    }

    match /users/{uid} {
      allow read, create, update, delete: if signedIn()
        && request.auth.uid == uid;
    }

    match /farms/{farmId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow read: if isFarmMember(farmId);
      allow update: if isFarmManager(farmId);
      allow delete: if isFarmOwner(farmId);

      match /members/{uid} {
        allow read: if isFarmMember(farmId);
        allow create: if isFarmManager(farmId)
          || isFarmCreator(farmId, uid)
          || hasValidInvite(farmId, uid);
        allow update: if isFarmManager(farmId)
          || (signedIn() && request.auth.uid == uid);
        allow delete: if isFarmManager(farmId)
          && uid != get(/databases/$(database)/documents/farms/$(farmId)).data.ownerId;
      }

      match /zones/{zoneId} {
        allow read: if isFarmMember(farmId);
        allow create, update, delete: if isFarmManager(farmId);
      }

      match /ponds/{pondId} {
        allow read: if isFarmMember(farmId);
        allow create, update, delete: if isFarmManager(farmId);
      }

      match /fertilizers/{fertilizerId} {
        allow read: if isFarmMember(farmId);
        allow create, update, delete: if isFarmManager(farmId);
      }

      match /feedingRecords/{recordId} {
        allow read, create, update: if isFarmMember(farmId);
        allow delete: if isFarmManager(farmId);
      }

      match /patrolRecords/{recordId} {
        allow read, create, update: if isFarmMember(farmId);
        allow delete: if isFarmManager(farmId);
      }

      match /fertilizingRecords/{recordId} {
        allow read, create, update: if isFarmMember(farmId);
        allow delete: if isFarmManager(farmId);
      }

      match /harvestRecords/{recordId} {
        allow read, create, update: if isFarmMember(farmId);
        allow delete: if isFarmManager(farmId);
      }
    }

    match /farmInvites/{inviteId} {
      allow create: if signedIn()
        && isFarmManager(request.resource.data.farmId);
      allow read: if signedIn()
        && (resource.data.phone == request.auth.token.phone_number
          || isFarmManager(resource.data.farmId));
      allow update: if signedIn()
        && (resource.data.phone == request.auth.token.phone_number
          || isFarmManager(resource.data.farmId));
      allow delete: if signedIn()
        && isFarmManager(resource.data.farmId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
